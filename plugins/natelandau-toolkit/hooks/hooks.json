{
  "description": "Unified PreToolUse dispatcher (branch, secrets, system, commit-message, uv) plus the Stop phrase guard and follow-up capture.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre_tool_dispatcher.py",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop_phrase_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/capture_followups.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
