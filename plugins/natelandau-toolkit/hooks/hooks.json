{
  "description": "Per-stage PreToolUse dispatcher (branch, secrets, system, commit-message, uv).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
