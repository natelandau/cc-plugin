# Copy to ~/.claude/natelandau-recall.toml (global) or
# <project>/.claude/natelandau-recall.toml (per-project; project wins).
# All keys are optional; omitting the file uses the defaults shown.

[inject]
enabled = true                # set false to stop SessionStart memory injection

[sweep]
enabled = true                # set false to stop the end-of-session sweep
model = "claude-sonnet-4-6"   # model for the headless sweep
min_exchanges = 10            # skip the sweep below this many real messages (user + assistant)
